<Window x:Class="WpfApp1.EditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Заголовок" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

        <!-- Контейнер для полей ввода -->
        <StackPanel x:Name="FieldsContainer" Grid.Row="1" Orientation="Vertical">
            <!-- Поля будут добавляться программно из C# -->
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Click="Save_Click" Width="100" Height="30" 
                    Background="#27AE60" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="100" Height="30" 
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>