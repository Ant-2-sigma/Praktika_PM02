<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Муниципальные олимпиады - Система управления" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Стили для кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1ABC9C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#16A085"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="100"/>
            <!-- Чуть шире для текста Excel -->
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- Шаблоны данных (Views) -->
        <DataTemplate x:Key="TeachersView">
            <DataGrid ItemsSource="{Binding Teachers}" SelectedItem="{Binding SelectedItem}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ФИО учителя" Binding="{Binding ФИО}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <DataTemplate x:Key="StudentsView">
            <DataGrid ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedItem}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding Фамилия}" Width="120"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Имя}" Width="120"/>
                    <DataGridTextColumn Header="Отчество" Binding="{Binding Отчество}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" Width="120"/>
                    <DataGridComboBoxColumn Header="Класс" 
                        ItemsSource="{Binding DataContext.Classes, RelativeSource={RelativeSource AncestorType=Window}}"
                        DisplayMemberPath="Название" SelectedValuePath="ID"
                        SelectedValueBinding="{Binding Класс_ID}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <DataTemplate x:Key="OlympiadsView">
            <DataGrid ItemsSource="{Binding Olympiads}" SelectedItem="{Binding SelectedItem}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Название олимпиады" Binding="{Binding Название}" Width="*"/>
                    <DataGridTextColumn Header="Предмет" Binding="{Binding Предмет}" Width="150"/>
                    <DataGridTextColumn Header="Дата проведения" Binding="{Binding Дата_проведения, StringFormat=dd.MM.yyyy}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>

        <DataTemplate x:Key="ParticipationsView">
            <DataGrid ItemsSource="{Binding Participations}" SelectedItem="{Binding SelectedItem}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="40" IsReadOnly="True"/>
                    <DataGridComboBoxColumn Header="Школьник" 
                        ItemsSource="{Binding DataContext.Students, RelativeSource={RelativeSource AncestorType=Window}}"
                        DisplayMemberPath="Фамилия" SelectedValuePath="ID"
                        SelectedValueBinding="{Binding Школьник_ID}" Width="150"/>
                    <DataGridComboBoxColumn Header="Олимпиада" 
                        ItemsSource="{Binding DataContext.Olympiads, RelativeSource={RelativeSource AncestorType=Window}}"
                        DisplayMemberPath="Название" SelectedValuePath="ID"
                        SelectedValueBinding="{Binding Олимпиада_ID}" Width="180"/>
                    <DataGridComboBoxColumn Header="Класс выполнения" 
                        ItemsSource="{Binding DataContext.Classes, RelativeSource={RelativeSource AncestorType=Window}}"
                        DisplayMemberPath="Название" SelectedValuePath="ID"
                        SelectedValueBinding="{Binding Класс_за_который_выполнял_ID}" Width="100"/>
                    <DataGridComboBoxColumn Header="Учитель" 
                        ItemsSource="{Binding DataContext.Teachers, RelativeSource={RelativeSource AncestorType=Window}}"
                        DisplayMemberPath="ФИО" SelectedValuePath="ID"
                        SelectedValueBinding="{Binding Учитель_ID}" Width="200"/>
                    <DataGridTextColumn Header="Баллы" Binding="{Binding Количество_баллов}" Width="80"/>
                    <DataGridTextColumn Header="Результат" Binding="{Binding Результат_участия}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Background="#1ABC9C" Height="80" Margin="0,0,0,20">
                    <TextBlock Text="Муниципальные&#xA;олимпиады" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="White" 
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>

                <Button Content="📚 Учителя" Command="{Binding ShowTeachersCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="👨‍🎓 Школьники" Command="{Binding ShowStudentsCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="🏆 Олимпиады" Command="{Binding ShowOlympiadsCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="📝 Участия" Command="{Binding ShowParticipationsCommand}" Style="{StaticResource MenuButtonStyle}"/>

                <Separator Margin="10,20,10,10" Background="#7F8C8D" Height="2"/>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="10" Padding="8" 
                         Background="#34495E" Foreground="White"
                         BorderThickness="0" FontSize="12"
                         ToolTip="Поиск...">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>

                <Button Content="💾 Сохранить изменения" Command="{Binding SaveCommand}"
                        Style="{StaticResource MenuButtonStyle}" Background="#27AE60"/>

                <TextBlock Text="© 2026 Система управления" 
                           FontSize="10" Foreground="#7F8C8D"
                           HorizontalAlignment="Center" Margin="0,30,0,10"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Панель действий -->
            <Border Grid.Row="0" Background="#ECF0F1" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <Button Content="➕ Добавить" Command="{Binding AddCommand}" 
                            Style="{StaticResource ActionButtonStyle}" Background="#27AE60"/>
                    <Button Content="✏️ Редактировать" Command="{Binding EditCommand}" 
                            Style="{StaticResource ActionButtonStyle}" Background="#F39C12"/>
                    <Button Content="🗑️ Удалить" Command="{Binding DeleteCommand}" 
                            Style="{StaticResource ActionButtonStyle}" Background="#E74C3C"/>

                    <!-- Добавь это рядом с другими кнопками в StackPanel панели действий -->
                    <Button Content="🌐 Тест API" Command="{Binding TestApiCommand}" 
        Style="{StaticResource ActionButtonStyle}" Background="#8E44AD"/>

                    <Border Width="1" Background="#BDC3C7" Margin="10,0"/>

                    <!-- Кнопки Excel -->
                    <Button Content="📥 Экспорт Excel" Command="{Binding ExportExcelCommand}" 
                            Style="{StaticResource ActionButtonStyle}" Background="#217346"/>
                    <Button Content="📤 Импорт Excel" Command="{Binding ImportExcelCommand}" 
                            Style="{StaticResource ActionButtonStyle}" Background="#217346"/>

                    <Border Width="1" Background="#BDC3C7" Margin="10,0"/>

                    <TextBlock Text="Выберите строку для редактирования или удаления" 
                               VerticalAlignment="Center" Foreground="#7F8C8D" FontSize="11"/>
                </StackPanel>
            </Border>

            <!-- Контент с переключением видов -->
            <ContentControl Grid.Row="1" Content="{Binding .}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource TeachersView}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Teachers">
                                <Setter Property="ContentTemplate" Value="{StaticResource TeachersView}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Students">
                                <Setter Property="ContentTemplate" Value="{StaticResource StudentsView}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Olympiads">
                                <Setter Property="ContentTemplate" Value="{StaticResource OlympiadsView}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Participations">
                                <Setter Property="ContentTemplate" Value="{StaticResource ParticipationsView}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <!-- Статус бар -->
            <Border Grid.Row="2" Background="#ECF0F1" Padding="10" CornerRadius="5" Margin="0,10,0,0">
                <TextBlock Text="Готов к работе. Данные загружаются из базы DESKTOP-159LLU1\KAMI0YASU" 
                           Foreground="#7F8C8D" FontSize="11"/>
            </Border>
        </Grid>
    </Grid>
</Window>